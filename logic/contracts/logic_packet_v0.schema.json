{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://omnicron.local/schemas/logic_packet_v0.schema.json",
  "title": "Logic Packet v0",
  "description": "A framed reconstructive packet: send seed, rules, witness, and expected hash instead of sending a finished artifact.",
  "type": "object",
  "required": [
    "type",
    "version",
    "id",
    "preheader_commitment",
    "preheader_stream",
    "delta_law",
    "origin",
    "rule_lut",
    "rewrite_program",
    "projection",
    "expected"
  ],
  "properties": {
    "type": { "const": "logic_packet" },
    "version": { "const": "v0" },
    "id": { "type": "string", "minLength": 1 },
    "description": { "type": "string" },
    "preheader_commitment": {
      "type": "array",
      "minItems": 6,
      "maxItems": 6,
      "items": { "type": "integer", "minimum": 0, "maximum": 255 }
    },
    "preheader_stream": {
      "type": "array",
      "minItems": 1,
      "items": {
        "oneOf": [
          { "type": "integer", "minimum": 0, "maximum": 255 },
          {
            "type": "object",
            "required": ["byte"],
            "properties": {
              "byte": { "type": "integer", "minimum": 0, "maximum": 255 },
              "interpret_as": { "type": "string" },
              "expected_header8": {
                "type": "array",
                "minItems": 8,
                "maxItems": 8,
                "items": { "type": "integer", "minimum": 0, "maximum": 255 }
              }
            },
            "additionalProperties": false
          }
        ]
      }
    },
    "delta_law": {
      "type": "object",
      "required": ["id", "width_bits", "rotl", "rotr", "operator", "constant", "mask"],
      "properties": {
        "id": { "const": "rotl1_xor_rotl3_xor_rotr2_xor_C" },
        "width_bits": { "type": "integer", "enum": [8, 16, 32, 64, 128, 256, 512] },
        "rotl": {
          "type": "array",
          "items": { "type": "integer" },
          "minItems": 2,
          "maxItems": 2
        },
        "rotr": {
          "type": "array",
          "items": { "type": "integer" },
          "minItems": 1,
          "maxItems": 1
        },
        "operator": { "const": "xor" },
        "constant": { "type": "integer", "minimum": 0 },
        "mask": { "type": "string", "minLength": 1 }
      },
      "additionalProperties": false
    },
    "origin": {
      "type": "object",
      "required": ["seed"],
      "properties": {
        "seed": { "type": "integer", "minimum": 0, "maximum": 255 },
        "label": { "type": "string" }
      },
      "additionalProperties": false
    },
    "rule_lut": {
      "type": "object",
      "description": "Named rewrite constants; peers may repair a packet by supplying missing entries.",
      "additionalProperties": {
        "type": "integer",
        "minimum": -255,
        "maximum": 255
      }
    },
    "rewrite_program": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["op"],
        "properties": {
          "op": { "enum": ["emit_seed", "add_emit", "xor_emit", "lut_add_emit", "delta_emit"] },
          "value": { "type": "integer", "minimum": -255, "maximum": 255 },
          "key": { "type": "string" },
          "repeat": { "type": "integer", "minimum": 1, "maximum": 1024 }
        },
        "additionalProperties": false
      }
    },
    "projection": {
      "type": "object",
      "required": ["target"],
      "properties": {
        "target": { "enum": ["bytes", "text", "render_packet"] },
        "encoding": { "type": "string" }
      },
      "additionalProperties": false
    },
    "expected": {
      "type": "object",
      "required": ["artifact_sha256"],
      "properties": {
        "artifact_sha256": { "type": "string", "pattern": "^[0-9a-f]{64}$" },
        "artifact_text": { "type": "string" },
        "preheader_witness_sha256": { "type": "string", "pattern": "^[0-9a-f]{64}$" }
      },
      "additionalProperties": false
    },
    "repair_hints": {
      "type": "array",
      "items": { "type": "string" }
    }
  },
  "additionalProperties": false
}
