% Coreform chain root
coreform_root(coreform_001).

% Linked-list structure (authoritative)
node(coreform_001_n0, node_meta(coreform_001, 0)).
node(coreform_001_n1, node_meta(coreform_001, 1)).
node(coreform_001_n2, node_meta(coreform_001, 2)).
node(coreform_001_n3, node_meta(coreform_001, 3)).

next(coreform_001_n0, coreform_001_n1).
next(coreform_001_n1, coreform_001_n2).
next(coreform_001_n2, coreform_001_n3).

% Mandatory stage sequence
stage(coreform_001_n0, truth_table).
stage(coreform_001_n1, karnaugh).
stage(coreform_001_n2, gate_net).
stage(coreform_001_n3, carry_lookahead).

% Derivation lineage
derives_from(coreform_001_n0, bitroll7).
derives_from(coreform_001_n1, coreform_001_n0).
derives_from(coreform_001_n2, coreform_001_n1).
derives_from(coreform_001_n3, coreform_001_n2).

% Deterministic routing bindings
virtual_address(coreform_001_n0, 'va:0000a001:0.0.00').
virtual_address(coreform_001_n1, 'va:0000a001:1.0.15').
virtual_address(coreform_001_n2, 'va:0000a001:2.0.30').
virtual_address(coreform_001_n3, 'va:0000a001:3.0.45').

