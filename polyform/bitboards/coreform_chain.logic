% Primitive constitutional law
primitive_operation(bitroll7).
bitroll_law(bitroll7, rotl1_xor_rotl3_xor_rotr2_xor_c).

% Derived constants from constitutional terms
derived_constant(ch0_binary, channel_range(0, 15)).
