{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://omnicron.local/prolog/canonicality_attestation.schema.json",
  "title": "Canonicality Attestation",
  "type": "object",
  "required": [
    "type",
    "command",
    "timestamp_utc",
    "revision",
    "stages",
    "render_packet_hash_ok",
    "render_packet_schema_ok",
    "render_packet_provenance_ok",
    "render_contract_ok",
    "deterministic_hash_ok",
    "provenance_complete",
    "canonicality_ok"
  ],
  "properties": {
    "type": { "const": "canonicality_attestation" },
    "command": { "type": "string" },
    "timestamp_utc": { "type": "string" },
    "revision": { "type": "string" },
    "stages": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["id", "name", "status"],
        "properties": {
          "id": { "type": "string" },
          "name": { "type": "string" },
          "status": { "enum": ["pass", "fail"] },
          "detail": { "type": "string" }
        },
        "additionalProperties": false
      }
    },
    "render_packet_hash_ok": { "type": "boolean" },
    "render_packet_schema_ok": { "type": "boolean" },
    "render_packet_provenance_ok": { "type": "boolean" },
    "render_contract_ok": { "type": "boolean" },
    "deterministic_hash_ok": { "type": "boolean" },
    "provenance_complete": { "type": "boolean" },
    "canonicality_ok": { "type": "boolean" }
  },
  "additionalProperties": false
}
